# =====================================
# Vietnamese Medical Chatbot - .env.example
# Copy file này thành .env và điền giá trị thật.
# =====================================

# ---------- App metadata ----------
APP_NAME=Medical RAG Chatbot
APP_VERSION=1.0.0

# ---------- OpenTelemetry / Tempo ----------
TEMPO_ENABLED=false
TEMPO_ENDPOINT=http://localhost:4317

# ---------- Qdrant ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
DEFAULT_COLLECTION_NAME=medical_data

# ---------- Embedding ----------
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
VECTOR_DIMENSION=1024
DEVICE=cpu

# ---------- Generation providers ----------
QWEN3_MODELS_ENABLED=true
QWEN3_MODELS_URL=http://localhost:7860
BACKEND_API_URL=http://localhost:8000

VLLM_URL=http://localhost:7861
OLLAMA_URL=http://localhost:11434
OLLAMA_THINK=false
MODEL_NAME=

# ---------- Internal HTTP resilience ----------
SERVICE_HTTP_TIMEOUT=60
SERVICE_HTTP_RETRIES=2
SERVICE_HTTP_BACKOFF_SECONDS=0.4

# ---------- Search / processing ----------
TOP_K=5
BATCH_SIZE=500
MAX_WORKERS=4

# ---------- Data paths ----------
DATA_DIR=data/processed
CHUNKS_OUTPUT_DIR=data/chunks

# ---------- Elasticsearch ----------
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=medical_documents

# ---------- Redis (optional) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------- Security ----------
JWT_SECRET_KEY=change-me-in-production-please

# ---------- External APIs ----------
OPENAI_API_KEY=
TAVILY_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=A5w1fw5x0uXded1LDvZp

# ---------- STT/TTS ----------
STT_GPU_SERVICE_URL=http://extra_models:8002
STT_CACHE_TTL=3600
TTS_CACHE_TTL=86400

# ---------- PostgreSQL ----------
POSTGRES_USER=postgresadmin
POSTGRES_PASSWORD=postgresadmin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_rag_db

# ---------- Frontend (optional, nếu frontend dùng .env root) ----------
VITE_API_URL=http://localhost:8000
VITE_TTS_VOICE_ID=
VITE_STT_AUTO_SEND=false
VITE_STT_MAX_RECORDING_MS=20000
